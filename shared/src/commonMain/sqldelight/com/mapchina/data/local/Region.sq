CREATE TABLE region (
    id TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL,
    level TEXT NOT NULL,
    parent_id TEXT,
    boundary_json TEXT
);

selectById:
SELECT * FROM region WHERE id = ?;

selectByParentId:
SELECT * FROM region WHERE parent_id = ? ORDER BY name;

selectByLevel:
SELECT * FROM region WHERE level = ? ORDER BY name;

selectBoundariesByParentId:
SELECT id, boundary_json FROM region WHERE parent_id = ? AND boundary_json IS NOT NULL;

selectBoundariesByLevel:
SELECT id, boundary_json FROM region WHERE level = ? AND boundary_json IS NOT NULL;

selectByParentIdRecursive:
SELECT * FROM region WHERE parent_id IN (
    SELECT id FROM region WHERE parent_id = ?
);

insertRegion:
INSERT OR IGNORE INTO region(id, name, level, parent_id, boundary_json)
VALUES (?, ?, ?, ?, ?);

updateBoundary:
UPDATE region SET boundary_json = ? WHERE id = ?;

deleteByLevel:
DELETE FROM region WHERE level = ?;
